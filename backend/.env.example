# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# Render.com otomatik PORT atar; local'de SERVER_PORT kullanılır

# Database Configuration (local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=muhtar
DB_PASSWORD=muhtar123
DB_NAME=muhtar_db
DB_SSLMODE=disable

# Render.com managed PostgreSQL (production — DB_* yerine bunu kullanır)
# DATABASE_URL=postgres://user:pass@host:5432/muhtar_db?sslmode=require

# CORS — Vercel frontend URL'ini virgülle ekleyin
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka Configuration
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092

# JWT Configuration
JWT_SECRET=change-me-in-production-hackathon-2026
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# External APIs
